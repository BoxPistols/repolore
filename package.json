{
  "name": "repolore",
  "version": "0.5.0-alpha.0",
  "description": "Visualize a Git repository from multiple angles. Generates GitHub-native Mermaid (and later SVG, DOT, Wiki Markdown) from one command, with optional LLM curation.",
  "type": "module",
  "bin": {
    "repolore": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "mermaid",
    "diagram",
    "git",
    "repository",
    "visualization",
    "documentation",
    "architecture",
    "readme",
    "wiki"
  ],
  "author": "BoxPistols",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoxPistols/repolore.git"
  },
  "bugs": {
    "url": "https://github.com/BoxPistols/repolore/issues"
  },
  "homepage": "https://github.com/BoxPistols/repolore#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "cac": "^6.7.14",
    "picocolors": "^1.1.1",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
